# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Pipeline de noticias: búsqueda + extracción ───────────────────────────────
TAVILY_API_KEY=your-tavily-api-key
FIRECRAWL_API_KEY=your-firecrawl-api-key
CRON_SECRET=your-cron-secret

# ── Cadena de LLM (endpoints OpenAI-compatibles, con fallback automático) ──────
# Orden a intentar. Un proveedor sin API key se salta solo. Default: gemini,groq,cerebras
NEWS_LLM_CHAIN=gemini,groq,cerebras

# Principal: Gemini 2.5 Flash (Google AI Studio, free, 1M contexto). Key: aistudio.google.com
GEMINI_API_KEY=
# GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/openai   # (default)
# GEMINI_ANALYSIS_MODEL=gemini-2.5-flash        # análisis (default)
# GEMINI_SELECTION_MODEL=gemini-2.5-flash-lite  # selección/enriquecimiento (default)

# Fallback 1: Groq (free). Key: console.groq.com
OLLAMA_API_URL=https://api.groq.com/openai
OLLAMA_API_KEY=your-groq-api-key
OLLAMA_MODEL=llama-3.3-70b-versatile            # selección/enriquecimiento
NEWS_ANALYSIS_MODEL=openai/gpt-oss-120b         # análisis

# Fallback 2: Cerebras (free, ~1M tokens/día). Key: cloud.cerebras.ai
CEREBRAS_API_KEY=
# CEREBRAS_API_URL=https://api.cerebras.ai/v1   # (default)
# CEREBRAS_ANALYSIS_MODEL=llama-3.3-70b         # (default)
# CEREBRAS_SELECTION_MODEL=llama-3.3-70b        # (default)

# ── Búsqueda de tickers (legacy; el dashboard usa Yahoo Finance sin key) ───────
FINNHUB_API_KEY=your-finnhub-api-key
